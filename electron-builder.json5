{
   // Single source of truth cho electron-builder. KHÔNG dùng block `build` trong package.json
   // (electron-builder ưu tiên file `.json5` này → block `build` sẽ bị bỏ qua).
   $schema: 'https://raw.githubusercontent.com',
   appId: 'com.phongtro.app',
   asar: true,
   productName: 'PhongTroApp',
   directories: {
      output: 'release/${version}',
   },
   files: ['dist', 'dist-electron', 'migrations'],
   // Publish config cho electron-updater + auto-update qua GitHub Releases.
   publish: [
      {
         provider: 'github',
         owner: 'anhviet06',
         repo: 'PhongTro',
      },
   ],
   afterPack: './removeLocales.cjs',
   mac: {
      target: ['dmg'],
      artifactName: '${productName}-Mac-${version}-Installer.${ext}',
   },
   win: {
      target: [
         {
            target: 'nsis',
            arch: ['x64'],
         },
      ],
      icon: 'public/phong.png',
      artifactName: '${productName}-Windows-${version}-Setup.${ext}',
   },
   nsis: {
      // oneClick=true → installer chạy silent (cần thiết cho auto-update mượt).
      // Khi user ấn "Cập nhật", electron-updater quitAndInstall(silent=true) sẽ chạy
      // installer mới im lặng, ghi đè binary và re-launch — không cần user click gì.
      oneClick: true,
      perMachine: false,
      allowToChangeInstallationDirectory: false,
      createDesktopShortcut: 'always',
      shortcutName: 'PhongTroApp',
      uninstallDisplayName: 'PhongTroApp',
      // deleteAppDataOnUninstall=false → dữ liệu ở %APPDATA%/phongtro-app/ KHÔNG bị xóa
      // khi update (cũng như khi user gỡ cài). DB SQLite được giữ nguyên xuyên suốt.
      deleteAppDataOnUninstall: false,
      // differentialPackage=true (default) → user chỉ download delta giữa 2 version.
      artifactName: '${productName}-Setup-${version}.${ext}',
   },
   linux: {
      target: ['AppImage'],
      artifactName: '${productName}-Linux-${version}.${ext}',
   },
   extraResources: [
      {
         from: 'migrations',
         to: 'migrations',
      },
   ],
}
